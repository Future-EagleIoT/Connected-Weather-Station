# ============================================================
#  Backend Environment Variables
#  Copy to .env and fill in production values.
# ============================================================

# ---- App ----
APP_NAME=Connected Weather Station API
DEBUG=false

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/weather_station

# ---- JWT (generate with: openssl rand -hex 32) ----
JWT_SECRET_KEY=CHANGE-ME-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ---- Rate Limiting ----
RATE_LIMIT_DATA_PER_MIN=100
RATE_LIMIT_API_PER_MIN=30

# ---- CORS ----
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
